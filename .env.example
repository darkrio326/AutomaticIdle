# Copy this file to .env or .env.local before running deploy scripts.
# Do not commit real values.

# Static site deployment target
OSS_BUCKET=your-bucket-name
OSS_ENDPOINT=oss-cn-your-region.aliyuncs.com
OSS_PREFIX=

# Deploy behavior
RUN_BUILD=1
DELETE_REMOTE=0
DRY_RUN=0

# Frontend flags
VITE_ENABLE_ADSENSE=1
