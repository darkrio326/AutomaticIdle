{
  "name": "automatic-idle",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:runtime": "vitest run src/core/runtimeEngine.spec.ts",
    "tune:balance": "node scripts/tune-balance.mjs",
    "typecheck": "vue-tsc --noEmit",
    "format:json": "node scripts/format-json.mjs",
    "deploy:oss": "bash scripts/deploy-oss.sh",
    "deploy:oss:no-build": "RUN_BUILD=0 bash scripts/deploy-oss.sh"
  },
  "dependencies": {
    "pinia": "^2.1.7",
    "vue": "^3.4.21",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.4",
    "typescript": "^5.4.3",
    "vite": "^5.2.0",
    "vitest": "^4.1.2",
    "vue-tsc": "^2.0.6"
  }
}
